#!/bin/sh
# Pre-commit auto-fixer - formats and lint-fixes the STAGED files so every commit
# lands already clean, matching the static checks the pre-push / CI enforce.
#
# Only staged files are touched and re-staged; unstaged work and unrelated files
# are never modified. Formatting failures block the commit; residual (unfixable)
# lint errors do NOT - the pre-push hook is the hard gate, so commits stay quick.
#
# Installed automatically via the root package.json "prepare" script
# (git config core.hooksPath .githooks). Bypass in a pinch with:
#   git commit --no-verify
#
# Caveat: a partially-staged file (only some hunks staged) is re-staged whole, so
# its unstaged hunks get folded into the commit. Use --no-verify for those.
set -e

# Staged, still-present files (Added/Copied/Modified/Renamed).
staged="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -z "$staged" ] && exit 0

fmt_files="$(printf '%s\n' "$staged" | grep -Ei '\.(ts|tsx|js|jsx|cjs|mjs|css|json|jsonc|md|html)$' || true)"
lint_files="$(printf '%s\n' "$staged" | grep -Ei '\.(ts|tsx|js|jsx|cjs|mjs)$' || true)"

if [ -n "$fmt_files" ]; then
  echo "pre-commit: prettier --write"
  printf '%s\n' "$fmt_files" | xargs npx prettier --write --log-level warn || true
fi

if [ -n "$lint_files" ]; then
  echo "pre-commit: eslint --fix"
  
  frontend_files="$(printf '%s\n' "$lint_files" | grep '^frontend/' | sed 's/^frontend\///' || true)"
  if [ -n "$frontend_files" ]; then
    (cd frontend && printf '%s\n' "$frontend_files" | xargs npx eslint --fix || true)
  fi

  backend_files="$(printf '%s\n' "$lint_files" | grep '^backend/' | sed 's/^backend\///' || true)"
  if [ -n "$backend_files" ]; then
    (cd backend && printf '%s\n' "$backend_files" | xargs npx eslint --fix || true)
  fi
fi

# Re-stage only the files we just touched (-r: skip git add when none matched,
# e.g. an extension-less file like a hook was the only thing staged).
printf '%s\n' "$fmt_files" "$lint_files" | grep -v '^$' | sort -u | xargs -r git add

echo "pre-commit: ok"
