#!/bin/sh
# Pre-push gate - runs the static checks CI runs (typecheck + lint) so a push
# can't fail CI only after it reaches GitHub.
#
# Installed automatically via the root package.json "prepare" script
# (git config core.hooksPath .githooks). Bypass in a pinch with: git push --no-verify
set -e

# Skip when there's nothing new to push (git usually short-circuits this, but the
# guard also covers pushing an already-synced branch to a second remote): if no
# ref's local sha differs from the remote's, there's nothing to check.
has_work=''
while read -r _local_ref local_sha _remote_ref remote_sha; do
  case "$local_sha" in
    0000000000000000000000000000000000000000) continue ;; # branch deletion
  esac
  if [ "$local_sha" != "$remote_sha" ]; then
    has_work=1
  fi
done
if [ -z "$has_work" ]; then
  echo "pre-push: nothing new to push, skipping checks"
  exit 0
fi

# Skip when this exact commit already passed on a clean tree
head_sha="$(git rev-parse HEAD)"
stamp="$(git rev-parse --git-dir)/prepush-passed"
if [ "$(cat "$stamp" 2>/dev/null)" = "$head_sha" ] &&
  git diff --quiet &&
  git diff --cached --quiet; then
  echo "pre-push: HEAD already verified on a clean tree, skipping checks"
  exit 0
fi

echo "pre-push: typecheck frontend"
npm run typecheck

echo "pre-push: lint frontend"
npm run lint

echo "pre-push: lint backend"
npm run lint:backend

printf '%s' "$head_sha" >"$stamp"
echo "pre-push: all checks passed"
