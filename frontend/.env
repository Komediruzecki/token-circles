# Finance Manager — Default Environment Configuration
# These values are used for client-only (serverless) deployments.
# Override in .env.local for self-hosted/production setups.

# Default storage mode: "dexie" = client-only IndexedDB, "sqlite" = backend SQLite server
VITE_DEFAULT_STORAGE=dexie

# Site domain (used for CORS, OAuth redirects, etc.)
VITE_SITE_DOMAIN=localhost

# API base URL (only used in self-hosted mode)
VITE_API_BASE_URL=http://localhost:3847

# CORS allowed origins (comma-separated)
VITE_CORS_ORIGINS=http://localhost:3800,http://localhost:3847
