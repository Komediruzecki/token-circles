{
  "name": "finance-manager-frontend",
  "version": "2.0.0",
  "type": "module",
  "description": "Finance Manager Frontend - SolidJS + TypeScript",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tsc": "npx tsc",
    "vite": "npx vite",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write . --ignore-path .prettierignore",
    "fmt": "prettier . --write",
    "cloc": "cloc src --exclude-dir=node_modules,dist --by-file-by-lang --not-match-f='(.*[.]d[.]ts|.*[.]stories[.].*|.*[.]test[.].*|.*[.]json)'",
    "lines": "cloc src --exclude-dir=node_modules,dist --by-file-by-lang --not-match-f='(.*[.]d[.]ts|.*[.]stories[.].*|.*[.]test[.].*|.*[.]json)'"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "solid-js": "^1.8.15"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "cloc": "^2.6.0-cloc",
    "eslint": "9.39.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "28.1.0",
    "prettier": "3.8.3",
    "prettier-plugin-one-line-imports": "1.0.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.58.2",
    "vite": "^6.0.5",
    "vite-plugin-solid": "^2.11.12"
  }
}
