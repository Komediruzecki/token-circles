{
  "name": "finance-manager-frontend",
  "version": "5.4.0",
  "type": "module",
  "description": "Finance Manager Frontend - SolidJS + TypeScript",
  "author": "Komediruzecki",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Komediruzecki/finance-manager"
  },
  "bugs": {
    "url": "https://github.com/Komediruzecki/finance-manager/issues"
  },
  "homepage": "https://github.com/Komediruzecki/finance-manager#readme",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode dev",
    "deploy:dev": "pnpm run build:dev && npx wrangler deploy --env dev",
    "deploy:prod": "pnpm run build && npx wrangler deploy --env prod",
    "tsc": "npx tsc",
    "typecheck": "tsc --noEmit",
    "vite": "npx vite",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write . --ignore-path .prettierignore",
    "fmt": "prettier . --write",
    "cloc": "cloc src --exclude-dir=node_modules,dist --by-file-by-lang --not-match-f='(.*[.]d[.]ts|.*[.]stories[.].*|.*[.]test[.].*|.*[.]json)'",
    "lines": "cloc src --exclude-dir=node_modules,dist --by-file-by-lang --not-match-f='(.*[.]d[.]ts|.*[.]stories[.].*|.*[.]test[.].*|.*[.]json)'",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:unit": "vitest run",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "analyze-bundle": "VITE_ANALYZE_BUNDLE=true vite build"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/d3": "^7.4.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "solid-js": "^1.9.12",
    "xlsx": "file:../vendor/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.59.1",
    "@squoosh/lib": "^0.3.1",
    "@types/d3-sankey": "^0.12.5",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vitest/coverage-v8": "^4.1.5",
    "cloc": "^2.6.0-cloc",
    "eslint": "9.39.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-sonarjs": "^4.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "playwright": "^1.59.1",
    "prettier": "3.8.3",
    "prettier-plugin-one-line-imports": "1.0.3",
    "solid-devtools": "^0.34.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.58.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.9",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.0.18"
  }
}
