# Dev-environment BUILD vars — loaded only by `vite build --mode dev` (pnpm run build:dev).
# Never loaded by local `vite` dev (mode "development", uses .env) nor the prod build
# (mode "production", uses .env.production). Safe to commit: placeholders, no secrets.
# Fill PLACEHOLDER_DOMAIN before deploying the dev frontend.

# Dev frontend talks to the D1 worker API (server mode), not client-only IndexedDB.
VITE_DEFAULT_STORAGE=sqlite

# Absolute origin of the dev API worker. Same registrable domain as the app, so the
# session cookie (SameSite=Lax + COOKIE_DOMAIN=.dev.<domain> on the worker) is sent
# on these cross-subdomain XHRs. Empty/unset would fall back to same-origin /api.
VITE_API_URL=https://api.dev.PLACEHOLDER_DOMAIN

VITE_SITE_DOMAIN=dev.PLACEHOLDER_DOMAIN
