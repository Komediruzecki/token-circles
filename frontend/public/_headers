# Security headers for the static-asset (SPA) responses (audit S2/B1).
# Vite copies this file into dist/, which the Cloudflare Worker serves as the assets root.
#
# The enforcing Content-Security-Policy below stays minimal (framing/base-uri only) so it can't
# white-screen the app. The full content policy ships in REPORT-ONLY mode: the browser reports
# violations but blocks nothing, so it's safe to deploy and observe. Once the dev site confirms
# no legitimate violations, promote the report-only policy to an enforcing `Content-Security-Policy`
# (and drop the minimal one). The allow-list covers the app's own assets plus the third parties it
# loads: Stripe (js.stripe.com + payment frames), Cloudflare Turnstile, Google sign-in, the Worker
# API origins, and the exchange-rate API.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: frame-ancestors 'none'; base-uri 'self'; upgrade-insecure-requests
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://challenges.cloudflare.com https://accounts.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.dev.tokencircles.com https://api.tokencircles.com https://open.er-api.com https://challenges.cloudflare.com; frame-src https://js.stripe.com https://challenges.cloudflare.com https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
