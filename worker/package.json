{
  "name": "finance-manager-worker",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker + D1 API scaffold for Finance Manager (preparation; not yet live).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create finance-manager",
    "d1:migrate:local": "wrangler d1 migrations apply finance-manager --local",
    "d1:migrate:remote": "wrangler d1 migrations apply finance-manager --remote",
    "d1:exec:local": "wrangler d1 execute finance-manager --local --command",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
