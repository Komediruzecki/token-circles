db/*.db-shm
db/*.db-wal
db/sessions.db
backend/*.db
backend/*.db-shm
backend/*.db-wal
*.sqlite

# Uploaded files (track structure only)
!/assets/.gitkeep

# Build output
frontend/dist/
frontend/build/
frontend/vite/
frontend/node_modules/
frontend/test-results/
frontend/playwright-report/
frontend/coverage/
coverage/
frontend/assets/
