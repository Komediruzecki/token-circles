{
  "name": "finance-manager",
  "version": "1.1.0",
  "description": "Personal Finance Tracker",
  "main": "backend/index.js",
  "scripts": {
    "start": "node backend/index.js",
    "dev": "cd frontend && npm run dev",
    "test": "NODE_ENV=test NODE_PATH=./node_modules jest",
    "test:ci": "NODE_PATH=./node_modules jest --coverage",
    "test:watch": "NODE_PATH=./node_modules jest --watch",
    "test:backend": "NODE_PATH=./node_modules jest backend/",
    "test:frontend": "cd frontend && npm run test",
    "build": "cd frontend && npm run build",
    "format": "cd frontend && npm run format",
    "lint": "cd frontend && npm run lint"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.0",
    "puppeteer": "^24.41.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.59.1",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/index.js"
    ],
    "setupFilesAfterEnv": [
      "./test/jest.setup.js"
    ],
    "verbose": true
  }
}
