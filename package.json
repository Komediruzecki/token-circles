{
  "name": "finance-manager",
  "version": "1.1.0",
  "description": "Personal Finance Tracker - Monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "start": "cd backend && npm run start",
    "build": "cd frontend && npm run build",
    "lint": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "test": "cd frontend && npm run test",
    "test:backend": "NODE_ENV=test node_modules/.bin/jest --testPathPattern test/backend",
    "test:ci": "NODE_ENV=test node_modules/.bin/jest --coverage --testPathPattern test/backend",
    "format": "cd frontend && npm run format"
  }
}
