{
  "name": "finance-manager",
  "version": "4.0.0",
  "description": "Personal Finance Tracker - Monorepo Root",
  "private": true,
  "author": "Komediruzecki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Komediruzecki/finance-manager"
  },
  "bugs": {
    "url": "https://github.com/Komediruzecki/finance-manager/issues"
  },
  "homepage": "https://github.com/Komediruzecki/finance-manager#readme",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "cd frontend && npm run dev",
    "start": "cd backend && npm run start",
    "build": "cd frontend && npm run build",
    "lint": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "typecheck": "cd frontend && npm run typecheck",
    "format": "cd frontend && npm run format",
    "test": "cd frontend && npm run test",
    "test:backend": "cd backend && npm run test"
  },
  "devDependencies": {},
  "dependencies": {}
}
